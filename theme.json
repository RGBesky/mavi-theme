{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultPalette": false,
			"palette": [
				{
					"slug": "primary",
					"color": "#2C3A54",
					"name": "Bleu Marine (texte principal)"
				},
				{
					"slug": "secondary",
					"color": "#5A6A7E",
					"name": "Bleu Gris (texte secondaire)"
				},
				{
					"slug": "accent",
					"color": "#C1593B",
					"name": "Terracotta (accent)"
				},
				{
					"slug": "accent-light",
					"color": "#D97B5A",
					"name": "Terracotta Clair"
				},
				{
					"slug": "background",
					"color": "#FAF5EE",
					"name": "Crème (fond principal)"
				},
				{
					"slug": "surface",
					"color": "#F0E8DC",
					"name": "Sable (fond secondaire)"
				},
				{
					"slug": "surface-light",
					"color": "#F5EFE6",
					"name": "Sable Clair"
				},
				{
					"slug": "white",
					"color": "#FFFFFF",
					"name": "Blanc"
				},
				{
					"slug": "border",
					"color": "#D9CEBD",
					"name": "Bordure (sable foncé)"
				},
				{
					"slug": "navy-light",
					"color": "#3D4F6E",
					"name": "Bleu Marine Clair"
				},
				{
					"slug": "navy-bg",
					"color": "#E8ECF2",
					"name": "Bleu Marine (fond)"
				},
				{
					"slug": "terra-bg",
					"color": "#FAEAE3",
					"name": "Terracotta (fond)"
				},
				{
					"slug": "success-text",
					"color": "#3D7A57",
					"name": "Vert (texte)"
				},
				{
					"slug": "success-bg",
					"color": "#E8F3EB",
					"name": "Vert (fond)"
				},
				{
					"slug": "warning-text",
					"color": "#B8860B",
					"name": "Ambre (texte)"
				},
				{
					"slug": "warning-bg",
					"color": "#FDF3DC",
					"name": "Ambre (fond)"
				},
				{
					"slug": "danger-text",
					"color": "#C0392B",
					"name": "Rouge (texte)"
				},
				{
					"slug": "danger-bg",
					"color": "#FDECEB",
					"name": "Rouge (fond)"
				},
				{
					"slug": "info-text",
					"color": "#2C3A54",
					"name": "Info (texte)"
				},
				{
					"slug": "info-bg",
					"color": "#E8ECF2",
					"name": "Info (fond)"
				},
				{
					"slug": "notion-gray-bg",
					"color": "#F1F1EF",
					"name": "Notion Gris (fond)"
				},
				{
					"slug": "notion-brown-bg",
					"color": "#F4EEEE",
					"name": "Notion Marron (fond)"
				},
				{
					"slug": "notion-orange-bg",
					"color": "#FBECDD",
					"name": "Notion Orange (fond)"
				},
				{
					"slug": "notion-yellow-bg",
					"color": "#FBF3DB",
					"name": "Notion Jaune (fond)"
				},
				{
					"slug": "notion-green-bg",
					"color": "#EDF3EC",
					"name": "Notion Vert (fond)"
				},
				{
					"slug": "notion-blue-bg",
					"color": "#E7F3F8",
					"name": "Notion Bleu (fond)"
				},
				{
					"slug": "notion-purple-bg",
					"color": "#F6F3F9",
					"name": "Notion Violet (fond)"
				},
				{
					"slug": "notion-pink-bg",
					"color": "#FBF2F5",
					"name": "Notion Rose (fond)"
				},
				{
					"slug": "notion-red-bg",
					"color": "#FDEBEC",
					"name": "Notion Rouge (fond)"
				}
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFamily": "'Source Sans 3', 'Source Sans Pro', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
					"slug": "body",
					"name": "Body (Source Sans)"
				},
				{
					"fontFamily": "'Playfair Display', 'Georgia', 'Times New Roman', serif",
					"slug": "heading-serif",
					"name": "Heading Serif (Playfair)"
				},
				{
					"fontFamily": "'Source Sans 3', 'Source Sans Pro', -apple-system, BlinkMacSystemFont, sans-serif",
					"slug": "heading-sans",
					"name": "Heading Sans (Source Sans)"
				},
				{
					"fontFamily": "'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace",
					"slug": "code",
					"name": "Code (Monospace)"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "clamp(0.8125rem, 0.78rem + 0.16vw, 0.875rem)",
					"name": "Small (13–14px)",
					"fluid": false
				},
				{
					"slug": "medium",
					"size": "clamp(0.9375rem, 0.9rem + 0.19vw, 1rem)",
					"name": "Medium (15–16px)",
					"fluid": false
				},
				{
					"slug": "large",
					"size": "clamp(1.0625rem, 0.98rem + 0.42vw, 1.25rem)",
					"name": "Large (17–20px)",
					"fluid": false
				},
				{
					"slug": "x-large",
					"size": "clamp(1.25rem, 1.1rem + 0.75vw, 1.5rem)",
					"name": "X-Large (20–24px)",
					"fluid": false
				},
				{
					"slug": "xx-large",
					"size": "clamp(1.5rem, 1.25rem + 1.25vw, 2rem)",
					"name": "XX-Large (24–32px)",
					"fluid": false
				},
				{
					"slug": "xxx-large",
					"size": "clamp(1.75rem, 1.4rem + 1.75vw, 2.5rem)",
					"name": "XXX-Large (28–40px)",
					"fluid": false
				}
			]
		},
		"spacing": {
			"units": ["px", "em", "rem", "%", "vw", "vh"],
			"spacingSizes": [
				{
					"slug": "10",
					"size": "0.25rem",
					"name": "Tiny (4px)"
				},
				{
					"slug": "20",
					"size": "0.5rem",
					"name": "Small (8px)"
				},
				{
					"slug": "30",
					"size": "1rem",
					"name": "Medium (16px)"
				},
				{
					"slug": "40",
					"size": "1.5rem",
					"name": "Large (24px)"
				},
				{
					"slug": "50",
					"size": "2rem",
					"name": "X-Large (32px)"
				},
				{
					"slug": "60",
					"size": "3rem",
					"name": "XX-Large (48px)"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--primary)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.65"
		},
		"spacing": {
			"padding": {
				"top": "0",
				"right": "clamp(1rem, 4vw, 2rem)",
				"bottom": "0",
				"left": "clamp(1rem, 4vw, 2rem)"
			},
			"blockGap": "clamp(0.75rem, 2vw, 1rem)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading-serif)",
					"fontWeight": "700",
					"lineHeight": "1.25"
				},
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--primary)"
					}
				},
				"typography": {
					"textDecoration": "underline"
				}
			},
			"button": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontWeight": "600",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"lineHeight": "1.5"
				},
				"color": {
					"background": "var(--wp--preset--color--accent)",
					"text": "#FFFFFF"
				},
				"border": {
					"radius": "6px"
				},
				":hover": {
					"color": {
						"background": "#A84B30",
						"text": "#FFFFFF"
					}
				}
			},
			"caption": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				},
				"color": {
					"text": "var(--wp--preset--color--secondary)"
				}
			}
		},
		"blocks": {
			"core/code": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--code)",
					"fontSize": "0.9rem"
				},
				"color": {
					"background": "var(--wp--preset--color--surface)",
					"text": "var(--wp--preset--color--primary)"
				},
				"border": {
					"radius": "4px"
				},
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)"
					}
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--accent)",
						"width": "3px",
						"style": "solid"
					}
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--30)"
					}
				},
				"typography": {
					"fontStyle": "italic"
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--border)"
				},
				"border": {
					"width": "1px"
				}
			},
			"core/table": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)",
					"fontWeight": "700"
				}
			},
			"core/site-title": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "600"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var(--wp--preset--color--primary)"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "En-tête — Logo + Navigation",
			"area": "header"
		},
		{
			"name": "header-centered",
			"title": "En-tête — Centré",
			"area": "header"
		},
		{
			"name": "header-minimal",
			"title": "En-tête — Minimal (titre seul)",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Pied de page — Complet",
			"area": "footer"
		},
		{
			"name": "footer-minimal",
			"title": "Pied de page — Minimal",
			"area": "footer"
		}
	],
	"customTemplates": [
		{
			"name": "page-portfolio",
			"title": "Portfolio",
			"postTypes": ["page"]
		},
		{
			"name": "page-full-width",
			"title": "Plein écran (Full Width)",
			"postTypes": ["page", "post"]
		},
		{
			"name": "page-cover",
			"title": "Page avec bandeau",
			"postTypes": ["page", "post"]
		},
		{
			"name": "page-blank",
			"title": "Page sans bandeau (contenu seul)",
			"postTypes": ["page", "post"]
		},
		{
			"name": "page-no-header",
			"title": "Page sans en-tête",
			"postTypes": ["page"]
		}
	]
}
